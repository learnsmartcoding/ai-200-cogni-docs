# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it contains secrets. Only commit this .env.example file.
# =============================================================================

# ── Local Docker services (Phase 0) ──────────────────────────────────────────
POSTGRES_URL=postgresql://cogni:cogni_local@localhost:5432/cognidocs
REDIS_URL=redis://localhost:6379

# ── Phase 1a: Azure Blob Storage ─────────────────────────────────────────────
# Get this from: az storage account show-connection-string --name stcognidocs ...
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents

# ── Phase 1b: Azure Event Grid ────────────────────────────────────────────────
# (filled in during Phase 1b setup)
AZURE_FUNCTION_APP_NAME=

# ── Phase 1c: Azure Service Bus ───────────────────────────────────────────────
# Get this from: az servicebus namespace authorization-rule keys list ...
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_TOPIC=document-processing
AZURE_SERVICE_BUS_SUBSCRIPTION=embedding-worker
